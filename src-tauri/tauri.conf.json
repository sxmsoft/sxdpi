{
  "productName": "SxDPI",
  "version": "1.2.0",
  "identifier": "com.sxdpi.app",
  "app": {
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: wss: blob:;"
    },
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SxDPI",
        "width": 440,
        "height": 700,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ]
  },
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../x86_64"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {}
}
